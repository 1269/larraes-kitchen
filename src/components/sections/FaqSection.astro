---
import { ChevronDown } from "lucide-react";
import type { FaqGroup } from "@/lib/schemas/faq";

interface Props {
  id: string;
  faqGroups: FaqGroup[];
}
const { id, faqGroups } = Astro.props;

const sorted: FaqGroup[] = [...faqGroups].sort((a, b) => a.order - b.order);

const categoryLabel = (c: FaqGroup["category"]): string => {
  switch (c) {
    case "ordering":
      return "Ordering";
    case "delivery":
      return "Delivery & setup";
    case "menu-customization":
      return "Menu customization";
    case "payment":
      return "Payment";
  }
};

// FAQ-03: FAQPage JSON-LD structured data (static SSG emission)
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: sorted.flatMap((group) =>
    group.questions.map((q) => ({
      "@type": "Question",
      name: q.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: q.answer,
      },
    })),
  ),
};
---
<section id={id} class="bg-surface py-12 md:py-20 lg:py-24">
  <div class="max-w-3xl mx-auto px-5 md:px-8">
    <div class="max-w-[45rem]">
      <p class="text-eyebrow uppercase tracking-[0.12em] text-accent font-semibold">FREQUENTLY ASKED</p>
      <h2 class="mt-3 font-display text-display-lg text-ink">Answers, before you ask.</h2>
    </div>

    {sorted.map((group) => (
      <div class="mt-12 first:mt-8">
        <h3 class="font-serif italic text-display-md text-ink mb-4">{categoryLabel(group.category)}</h3>
        <ul class="flex flex-col divide-y divide-ink/10 border-t border-b border-ink/10">
          {group.questions.map((q) => (
            <li>
              <details class="group py-4 [&_summary::-webkit-details-marker]:hidden">
                <summary
                  class="flex items-center justify-between gap-4 cursor-pointer list-none min-h-[44px] text-body-lg text-ink font-semibold focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm"
                >
                  <span>{q.question}</span>
                  <ChevronDown
                    className="size-5 shrink-0 text-ink/60 transition-transform duration-200 group-open:rotate-180 group-open:text-primary motion-reduce:transition-none"
                    aria-hidden="true"
                  />
                </summary>
                <div class="mt-3 max-w-none text-body-md text-ink/80 leading-[1.65]">
                  {q.answer}
                </div>
              </details>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(faqJsonLd)}
  />
</section>
