---
import GalleryGrid from "@/components/GalleryGrid.tsx";
import type { GalleryImage } from "@/lib/schemas/gallery";

interface Props {
  id: string;
  gallery: GalleryImage[];
}
const { id, gallery } = Astro.props;

const sorted: GalleryImage[] = [...gallery].sort((a, b) => a.order - b.order);
---
<section id={id} class="bg-surface py-16 md:py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-5 md:px-8">
    <div class="max-w-[45rem]">
      <p class="text-eyebrow uppercase tracking-[0.12em] text-accent font-semibold">THE GALLERY</p>
      <h2 class="mt-3 font-display text-display-lg text-ink">Table settings that tell a story.</h2>
      <p class="mt-4 text-body-md text-ink/70 max-w-prose">
        A sampling of recent events — from backyard gatherings to corporate lunches.
      </p>
    </div>

    <div class="mt-12 md:mt-16">
      <GalleryGrid client:visible photos={sorted} />
    </div>
  </div>
</section>
