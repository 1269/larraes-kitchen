---
import { Picture } from "astro:assets";
import { Camera } from "lucide-react";
import type { AboutData } from "@/lib/schemas/about";

interface Props {
  id: string;
  about: AboutData;
}
const { id, about } = Astro.props;

const paragraphs = about.heritageNarrative.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
---
<section id={id} class="bg-surface py-12 md:py-20 lg:py-24">
  <div class="max-w-6xl mx-auto px-5 md:px-8">
    <div
      class="grid grid-cols-1 md:grid-cols-[1fr,1.2fr] md:gap-16 lg:gap-20 items-center"
    >
      {/* Right column on desktop = text; comes first on mobile so narrative leads */}
      <div class="order-1 md:order-2">
        <p class="text-eyebrow uppercase tracking-[0.12em] text-accent font-semibold">
          OUR KITCHEN
        </p>
        <h2 class="mt-3 font-display text-display-lg text-ink">
          Rooted in tradition, built in Benicia.
        </h2>
        <p class="mt-6 text-body-lg text-accent font-semibold">
          {about.positioning}
        </p>
        <div class="mt-6 max-w-prose">
          {paragraphs.map((p) => (
            <p class="mt-4 first:mt-0 text-body-lg text-ink/90 leading-[1.7]">
              {p}
            </p>
          ))}
        </div>
      </div>

      {/* Left column on desktop = portrait; comes second on mobile */}
      <div class="order-2 md:order-1 mt-10 md:mt-0">
        {about.chefPortrait && about.chefPortraitAlt ? (
          <Picture
            src={about.chefPortrait}
            alt={about.chefPortraitAlt}
            width={880}
            height={1100}
            widths={[360, 480, 640, 880]}
            sizes="(min-width: 768px) 440px, 360px"
            formats={["avif", "webp"]}
            loading="lazy"
            decoding="async"
            class="rounded-sm object-cover w-full max-w-[440px] mx-auto aspect-[4/5]"
          />
        ) : (
          <div
            class="aspect-[4/5] w-full max-w-[440px] mx-auto bg-clay/20 flex flex-col items-center justify-center rounded-sm text-center px-6"
            aria-label="Chef portrait placeholder"
          >
            <Camera className="size-8 text-ink/40 mb-3" aria-hidden="true" />
            <span class="text-body-sm text-ink/60">Portrait coming soon</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
