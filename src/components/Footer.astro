---
import type { SiteData } from "@/lib/schemas/site";
import { formatPhone } from "@/lib/format";

interface Props {
  site: SiteData;
}
const { site } = Astro.props;
const currentYear = new Date().getFullYear();
---
<footer>
  {/* Top band */}
  <div class="bg-surface py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-5 md:px-8">
      <div class="grid grid-cols-1 md:grid-cols-[2fr,1fr,1fr] gap-10 items-start">
        {/* Left: wordmark + NAP */}
        <div>
          <p class="font-display text-display-md text-ink">{site.name}</p>
          <address class="mt-4 text-body-sm text-ink/80 not-italic">
            {site.address.street}<br />
            {site.address.city}, {site.address.region} {site.address.postalCode}
          </address>
          <a
            href={`tel:${site.phone}`}
            class="mt-2 block text-body-sm text-ink hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm"
          >
            {formatPhone(site.phone)}
          </a>
          <a
            href={`mailto:${site.email}`}
            class="mt-1 block text-body-sm text-ink hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm"
          >
            {site.email}
          </a>
        </div>

        {/* Middle: explore */}
        <div>
          <p class="text-eyebrow uppercase tracking-[0.12em] text-ink/50 font-semibold">EXPLORE</p>
          <ul class="mt-4 flex flex-col gap-2 text-body-sm text-ink/80">
            <li><a href="#menu" class="hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm">Menu</a></li>
            <li><a href="#packages" class="hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm">Packages</a></li>
            <li><a href="#gallery" class="hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm">Gallery</a></li>
            <li><a href="#about" class="hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm">About</a></li>
            <li><a href="#faq" class="hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4 rounded-sm">FAQ</a></li>
          </ul>
        </div>

        {/* Right: connect */}
        <div>
          <p class="text-eyebrow uppercase tracking-[0.12em] text-ink/50 font-semibold">CONNECT</p>
          <div class="mt-4 flex gap-3">
            {site.social.instagram && (
              <a
                href={site.social.instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="flex items-center justify-center min-h-[44px] min-w-[44px] rounded-sm text-ink hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4"
              >
                {/* Instagram brand mark — inline SVG (lucide v1 removed brand icons) */}
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="20"
                  height="20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                </svg>
              </a>
            )}
            {site.social.facebook && (
              <a
                href={site.social.facebook}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="flex items-center justify-center min-h-[44px] min-w-[44px] rounded-sm text-ink hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4"
              >
                {/* Facebook brand mark — inline SVG (lucide v1 removed brand icons) */}
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="20"
                  height="20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                </svg>
              </a>
            )}
            {site.social.google && (
              <a
                href={site.social.google}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Google Business Profile"
                class="flex items-center justify-center min-h-[44px] min-w-[44px] rounded-sm text-ink hover:text-primary focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-4"
              >
                {/* Google Business uses Globe glyph (lucide Globe) — represents local listing */}
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="20"
                  height="20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10" />
                  <line x1="2" y1="12" x2="22" y2="12" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              </a>
            )}
          </div>
          {site.hours.length > 0 && (
            <div class="mt-6">
              <p class="text-eyebrow uppercase tracking-[0.12em] text-ink/50 font-semibold">HOURS</p>
              <ul class="mt-3 flex flex-col gap-1">
                {site.hours.map((h) => (
                  <li class="text-body-sm text-ink/70">{h.days} · {h.open}–{h.close}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  {/* Bottom strip */}
  <div class="bg-ink py-6">
    <div class="max-w-6xl mx-auto px-5 md:px-8 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-body-sm text-surface/60">© {currentYear} {site.name}. All rights reserved.</p>
      <nav aria-label="Legal" class="flex gap-4">
        <a href="#" data-pending="true" class="text-body-sm text-surface/60 hover:text-surface focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-4 rounded-sm">Privacy</a>
        <a href="#" data-pending="true" class="text-body-sm text-surface/60 hover:text-surface focus-visible:outline-2 focus-visible:outline-white focus-visible:outline-offset-4 rounded-sm">Terms</a>
      </nav>
    </div>
  </div>
</footer>
