# Every v1 env var name with placeholders.
# Register each of these in Vercel Preview + Production environments
# in Wave 7 with value "__placeholder__" (or equivalent); replace with
# real values in Phase 3 (Preview) and Phase 5 (Production).

# Email (Phase 3 wires, Phase 5 goes live)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Spam protection (Phase 3 wires, Phase 5 flips to prod keys)
# PUBLIC_ prefix required so Astro inlines the site key into the client bundle (Turnstile widget).
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Lead storage — Google Sheets (Phase 3)
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_LEAD_SHEET_ID=

# Cron auth — Vercel Cron bearer token for retry-email endpoint (LEAD-11)
CRON_SECRET=

# Resend webhook HMAC secret — verifies inbound delivery events (LEAD-12)
RESEND_WEBHOOK_SECRET=

# Error monitoring (Phase 4)
SENTRY_DSN=

# Public — available in client bundle
PUBLIC_SITE_URL=http://localhost:4321
